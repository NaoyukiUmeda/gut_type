{
  // Cloudflare Workers 静的アセット配信の設定。
  // `npm run build` が生成する out/ ディレクトリをそのまま配信する。
  // このファイルがあることで wrangler が Next.js を検知して
  // OpenNext アダプターを勝手に導入するのを防ぐ。
  "name": "gutype",
  "compatibility_date": "2026-05-21",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
